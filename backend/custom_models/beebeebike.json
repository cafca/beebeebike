{
  "priority": [
    { "if": "true",                                                   "multiply_by": "bike_priority" },
    { "if": "!bike_access && (!backward_bike_access || roundabout)",  "multiply_by": "0" },
    { "else_if": "!bike_access && backward_bike_access",              "multiply_by": "0.2" },
    { "if": "bike_road_access == PRIVATE",                            "multiply_by": "0.2" },
    { "if": "road_access == FORESTRY",                                "multiply_by": "0.6" },
    { "if": "road_access == AGRICULTURAL",                            "multiply_by": "0.6" },
    { "if": "road_access == MILITARY",                                "multiply_by": "0.1" },
    { "if": "road_environment == FERRY",                              "multiply_by": "0.3" },
    { "if": "road_environment == FORD",                               "multiply_by": "0.2" },
    { "if": "mtb_rating > 2",                                         "multiply_by": "0" },

    { "if": "cycleway == TRACK",                                      "multiply_by": "1.3" },
    { "if": "cycleway == LANE",                                       "multiply_by": "1.1" },
    { "if": "get_off_bike == true",                                   "multiply_by": "0.6" },
    { "if": "surface == COBBLESTONE",                                 "multiply_by": "0.5" },
    { "if": "surface == SAND || surface == GROUND || surface == DIRT","multiply_by": "0.7" }
  ],
  "speed": [
    { "if": "true",                                                   "limit_to": "bike_average_speed" },
    { "if": "!bike_access && backward_bike_access",                   "limit_to": "6" },
    { "if": "surface == COBBLESTONE",                                 "multiply_by": "0.75" },
    { "if": "surface == PAVING_STONES",                               "multiply_by": "0.9" },
    { "if": "surface == GRAVEL || surface == FINE_GRAVEL || surface == COMPACTED", "multiply_by": "0.9" },
    { "if": "average_slope > 6",                                      "multiply_by": "0.7" },
    { "if": "average_slope > 12",                                     "multiply_by": "0.5" },
    { "if": "average_slope < -6",                                     "multiply_by": "1.2" }
  ],
  "distance_influence": 60
}
